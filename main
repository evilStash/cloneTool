local function setRect(a,b)
    local tl = Vector2.new(math.min(a.X,b.X), math.min(a.Y,b.Y))
    local sz = Vector2.new(math.abs(b.X-a.X), math.abs(b.Y-a.Y))
    RectBorder.Position=tl; RectBorder.Size=sz
    RectFill.Position=tl;   RectFill.Size=sz
end
local function showRect(v) RectBorder.Visible=v; RectFill.Visible=v end

local HitFolder = Instance.new("Folder")
HitFolder.Name="_CloneGizHit"; HitFolder.Parent=WS

local HitParts = {}
for _, key in ipairs(AXES_ORDER) do
    local p = Instance.new("Part")
    p.Name="GZHit_"..key; p.Anchored=true; p.CanCollide=false
    p.CanQuery=false; p.CastShadow=false; p.Transparency=1
    p.Size = Vector3.new(GZ_LEN, 1.5, 1.5); p.Parent=HitFolder
    HitParts[key] = p
end

local function placeHitParts(center)
    for _, key in ipairs(AXES_ORDER) do
        local d = AXIS_CFG[key].dir
        HitParts[key].CFrame = CFrame.lookAt(center, center+d) * CFrame.new(0,0,-GZ_LEN/2)
    end
end
local function setHitPartsActive(on)
    for _, p in pairs(HitParts) do p.CanQuery = on end
end
local function getHoveredAxis()
    local ray = Camera:ViewportPointToRay(Mouse.X, Mouse.Y)
    local rp = RaycastParams.new()
    rp.FilterType = Enum.RaycastFilterType.Include
    rp.FilterDescendantsInstances = { HitFolder }
    local res = WS:Raycast(ray.Origin, ray.Direction*800, rp)
    if res then return res.Instance.Name:sub(#"GZHit_" + 1) end
    return nil
end

local PrevFolder = Instance.new("Folder")
PrevFolder.Name="_ClonePreview"; PrevFolder.Parent=WS

local function clearPreview() PrevFolder:ClearAllChildren() end
local function spawnPreview()
    clearPreview()
    for _, brick in ipairs(S.bricks) do
        local p = Instance.new("Part")
        p.Anchored=true; p.CanCollide=false; p.CanQuery=false; p.CastShadow=false
        p.Color=brick.Color; p.Material=brick.Material; p.Size=brick.Size
        p.CFrame=brick.CFrame+S.off; p.Transparency=0.5; p.Parent=PrevFolder
    end
end
local function refreshPreview()
    local kids = PrevFolder:GetChildren()
    for i, p in ipairs(kids) do
        if S.bricks[i] then p.CFrame = S.bricks[i].CFrame + S.off end
    end
end

local trackedBricks = {}

local function trackFolder(folder)
    for _, brick in ipairs(folder:GetChildren()) do
        if brick:IsA("BasePart") and brick.Name == "Brick" then
            trackedBricks[brick] = true
        end
    end
    folder.ChildAdded:Connect(function(brick)
        if brick:IsA("BasePart") and brick.Name == "Brick" then
            trackedBricks[brick] = true
        end
    end)
    folder.ChildRemoved:Connect(function(brick)
        trackedBricks[brick] = nil
    end)
end

local function getAllBricks()
    local t = {}
    for brick in pairs(trackedBricks) do
        if brick and brick.Parent then
            table.insert(t, brick)
        else
            trackedBricks[brick] = nil
        end
    end
    return t
end

local BrickRoot = WS:WaitForChild("Bricks")
for _, folder in ipairs(BrickRoot:GetChildren()) do
    trackFolder(folder)
end
BrickRoot.ChildAdded:Connect(function(folder)
    trackFolder(folder)
end)

local function brickInScreenRect(brick, min2, max2)
    local cf = brick.CFrame; local hs = brick.Size/2
    for _, c in ipairs(CORNERS) do
        local vp = Camera:WorldToViewportPoint((cf*CFrame.new(hs*c)).Position)
        if vp.Z>0 and vp.X>=min2.X and vp.X<=max2.X and vp.Y>=min2.Y and vp.Y<=max2.Y then
            return true
        end
    end
    return false
end

local function calcBounds(bricks)
    local INF = math.huge
    local mn = Vector3.new(INF,INF,INF); local mx = Vector3.new(-INF,-INF,-INF)
    for _, brick in ipairs(bricks) do
        local cf = brick.CFrame; local hs = brick.Size/2
        for _, c in ipairs(CORNERS) do
            local wp = (cf*CFrame.new(hs*c)).Position
            mn = Vector3.new(math.min(mn.X,wp.X), math.min(mn.Y,wp.Y), math.min(mn.Z,wp.Z))
            mx = Vector3.new(math.max(mx.X,wp.X), math.max(mx.Y,wp.Y), math.max(mx.Z,wp.Z))
        end
    end
    return (mn+mx)/2, mx-mn
end

local function snapV3(v)
    return Vector3.new(
        math.round(v.X/SNAP_GRID)*SNAP_GRID,
        math.round(v.Y/SNAP_GRID)*SNAP_GRID,
        math.round(v.Z/SNAP_GRID)*SNAP_GRID
    )
end

local function bestPlaneNormal(ax)
    local fwd = Camera.CFrame.LookVector
    if ax=="X" then
        local ny,nz = Vector3.new(0,1,0), Vector3.new(0,0,1)
        return math.abs(fwd:Dot(ny))>=math.abs(fwd:Dot(nz)) and ny or nz
    elseif ax=="Y" then
        local nx,nz = Vector3.new(1,0,0), Vector3.new(0,0,1)
        return math.abs(fwd:Dot(nx))>=math.abs(fwd:Dot(nz)) and nx or nz
    else
        local nx,ny = Vector3.new(1,0,0), Vector3.new(0,1,0)
        return math.abs(fwd:Dot(nx))>=math.abs(fwd:Dot(ny)) and nx or ny
    end
end

local function rayPlane(ro, rd, pp, pn)
    local denom = rd:Dot(pn)
    if math.abs(denom)<1e-6 then return nil end
    local t = (pp-ro):Dot(pn)/denom
    return t>0 and (ro+rd*t) or nil
end

local function notify(title, text, dur)
    StarterGui:SetCore("SendNotification", { Title=title, Text=text, Duration=dur or 3 })
end

local function hasPlacementOverlap()
    local kids = PrevFolder:GetChildren()
    if #kids == 0 then return false end
    local sourceSet = {}
    for _, b in ipairs(S.bricks) do sourceSet[b] = true end
    local params = OverlapParams.new()
    params.FilterType = Enum.RaycastFilterType.Include
    params.FilterDescendantsInstances = { BrickRoot }
    for _, preview in ipairs(kids) do
        local ok, found = pcall(function()
            return WS:GetPartsInPart(preview, params)
        end)
        if ok and found then
            for _, part in ipairs(found) do
                if not sourceSet[part] then return true end
            end
        end
    end
    return false
end

local MAT_STR = {
    [Enum.Material.SmoothPlastic]="smooth",  [Enum.Material.Plastic]     ="plastic",
    [Enum.Material.CeramicTiles] ="tiles",   [Enum.Material.Brick]       ="bricks",
    [Enum.Material.WoodPlanks]   ="planks",  [Enum.Material.Ice]         ="ice",
    [Enum.Material.Grass]        ="grass",   [Enum.Material.Sand]        ="sand",
    [Enum.Material.Snow]         ="snow",    [Enum.Material.Glass]       ="glass",
    [Enum.Material.Wood]         ="wood",    [Enum.Material.Slate]       ="stone",
    [Enum.Material.Pebble]       ="pebble",  [Enum.Material.Marble]      ="marble",
    [Enum.Material.Granite]      ="granite", [Enum.Material.DiamondPlate]="steel",
    [Enum.Material.Metal]        ="metal",   [Enum.Material.Asphalt]     ="asphalt",
    [Enum.Material.Concrete]     ="concrete",[Enum.Material.Pavement]    ="pavement",
    [Enum.Material.Neon]         ="neon",
}

local function serializeBrick(brick, offset)
    local pos  = brick.Position + offset
    local size = brick.Size
    local isAnch  = brick:GetAttribute("OrigAnchored")   ~= nil and brick:GetAttribute("OrigAnchored")   or brick.Anchored
    local isCol   = brick:GetAttribute("OrigCanCollide") ~= nil and brick:GetAttribute("OrigCanCollide") or brick.CanCollide
    return {
        p  = { (pos.X-size.X/2)+0.5, (pos.Y-size.Y/2)+0.5, (pos.Z-size.Z/2)+0.5 },
        s  = { size.X, size.Y, size.Z },
        c  = { math.round(brick.Color.R*255), math.round(brick.Color.G*255), math.round(brick.Color.B*255) },
        m  = MAT_STR[brick.Material] or "smooth",
        o  = brick.Material.Name,
        a  = isAnch,
        cc = isCol,
        sp = {},
    }
end

local function findBrickIdxAtMouse(mx, my)
    local best, bestScore = nil, math.huge
    for i, b in ipairs(S.bricks) do
        local worldPos = b.CFrame.Position + S.off
        local vp = Camera:WorldToViewportPoint(worldPos)
        if vp.Z > 0 then
            local screenDist = (Vector2.new(vp.X, vp.Y) - Vector2.new(mx, my)).Magnitude
            local apparentR = math.clamp(
                (b.Size.Magnitude / (2 * vp.Z)) * Camera.ViewportSize.Y,
                24, 120
            )
            if screenDist <= apparentR and screenDist < bestScore then
                bestScore = screenDist
                best      = i
            end
        end
    end
    return best
end

function restoreSnapshot(snap)
    if S.ghostFolder then S.ghostFolder:Destroy(); S.ghostFolder = nil end
    S.phase="idle"; S.bricks={}; S.rawOff=Vector3.zero; S.off=Vector3.zero
    S.axis=nil; S.dragOrig=nil; S.hovAxis=nil; S.selectMode=false; S.hovBrickIdx=nil
    showRect(false); setHitPartsActive(false); clearPreview()
    SelModeGui.Enabled = false

    local ghosts = Instance.new("Folder")
    ghosts.Name   = "_CloneSnapGhosts"
    ghosts.Parent = WS
    S.ghostFolder = ghosts

    for _, bd in ipairs(snap.brickData) do
        local p = Instance.new("Part")
        p.Anchored    = true
        p.CanCollide  = false
        p.CanQuery    = false
        p.CastShadow  = false
        p.Transparency = 1
        p.CFrame      = bd.CFrame
        p.Size        = bd.Size
        p.Color       = bd.Color
        p.Material    = bd.Material
        p:SetAttribute("OrigAnchored",   bd.Anchored)
        p:SetAttribute("OrigCanCollide", bd.CanCollide)
        p.Parent = ghosts
        table.insert(S.bricks, p)
    end

    S.off     = snap.off
    S.rawOff  = snap.off
    S.bCenter = snap.center
    S.bSize   = snap.bSize

    S.phase = "selected"
    spawnPreview()
    placeHitParts(S.bCenter + S.off)
    setHitPartsActive(true)
    notify("Clone Tool", "Restored save ("..#S.bricks.." brick"..( #S.bricks==1 and "" or "s")..") at saved position  •  Q to place", 3)
end

local function resetTool()
    if S.ghostFolder then S.ghostFolder:Destroy(); S.ghostFolder = nil end
    S.phase="idle"; S.bricks={}; S.rawOff=Vector3.zero; S.off=Vector3.zero
    S.axis=nil; S.dragOrig=nil; S.hovAxis=nil; S.selectMode=false; S.hovBrickIdx=nil
    showRect(false); setHitPartsActive(false); clearPreview()
    SelModeGui.Enabled = false
end

local function confirmPlace()
    if S.phase~="selected" and S.phase~="dragging" then return end
    stopped = false
    if hasPlacementOverlap() then
        overlapFlashUntil = tick() + 0.5
        notify("Clone Tool", "⚠ Can't place — selection overlaps existing bricks!", 3)
        return
    end

    saveSnapshot()
    rebuildSavesUI()

    local count = 0
    for _, brick in ipairs(S.bricks) do
        if stopped then break end
        skipblock = false
        local d = serializeBrick(brick, S.off)
        local ghost = Instance.new("Part")
        ghost.Anchored   = true; ghost.CanCollide = false; ghost.CanQuery = false
        ghost.CastShadow = false; ghost.Transparency = 1
        ghost.Color      = Color3.fromRGB(d.c[1], d.c[2], d.c[3])
        ghost.Material   = Enum.Material[d.o] or Enum.Material.SmoothPlastic
        local sz = d.s and Vector3.new(d.s[1],d.s[2],d.s[3]) or Vector3.new(mult,mult,mult)
        ghost.Size = sz
        ghost.Position = Vector3.new(
            d.p[1] + (sz.X/2) - 0.5,
            d.p[2] + (sz.Y/2) - 0.5,
            d.p[3] + (sz.Z/2) - 0.5
        )
        ghost.Parent = WS
        oldprt = ghost
        buildblock(
            Vector3.new(d.p[1], d.p[2], d.p[3]),
            d.m,
            Color3.fromRGB(d.c[1],d.c[2],d.c[3]),
            nil, sz, true, d.o, d.sp, d.a, d.cc
        )
        count += 1
    end
    stopped = false
    resetTool()
    notify("Clone Tool", count.." brick(s) placed! ✔", 2)
end

Tool.Equipped:Connect(function()
    S.active = true
    ModeGui.Enabled = true
    notify("Clone Tool", "Drag to select  •  Arrows to move  •  Q to place  •  P (selected) select mode  •  Q (idle) saves  •  Z skip  •  X cancel k thx", 7)
end)
Tool.Unequipped:Connect(function()
    S.active = false
    ModeGui.Enabled = false
    SettingsGui.Enabled = false
    SavesGui.Enabled    = false
    SelModeGui.Enabled  = false
    resetTool()
end)

UIS.InputBegan:Connect(function(inp, gp)
    if gp or not S.active then return end

    if inp.KeyCode == Enum.KeyCode.Q then
        if S.phase == "selected" or S.phase == "dragging" then
            task.spawn(confirmPlace)
        else
            rebuildSavesUI()
            SavesGui.Enabled    = not SavesGui.Enabled
            SettingsGui.Enabled = false
        end
        return
    end

    if inp.KeyCode == Enum.KeyCode.P then
        if S.phase == "selected" or S.phase == "dragging" then
            S.selectMode       = not S.selectMode
            S.hovBrickIdx      = nil
            SelModeGui.Enabled = S.selectMode and S.active
        end
        return
    end

    if inp.KeyCode == Enum.KeyCode.Z then
        skipblock = true; return
    end
    if inp.KeyCode == Enum.KeyCode.X then
        stopped = true; resetTool(); return
    end
    if inp.KeyCode == Enum.KeyCode.Escape then
        if SettingsGui.Enabled then
            SettingsGui.Enabled = false
        elseif SavesGui.Enabled then
            SavesGui.Enabled = false
        elseif S.selectMode then
            S.selectMode = false; S.hovBrickIdx = nil
            SelModeGui.Enabled = false
        else
            resetTool()
        end
        return
    end

    if inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end

    SavesGui.Enabled    = false
    SettingsGui.Enabled = false

    local mx, my = Mouse.X, Mouse.Y

    if S.selectMode and (S.phase == "selected" or S.phase == "dragging") then
        local idx = findBrickIdxAtMouse(mx, my)
        if idx then
            table.remove(S.bricks, idx)
            if #S.bricks > 0 then
                S.bCenter, S.bSize = calcBounds(S.bricks)
                clearPreview(); spawnPreview()
                placeHitParts(S.bCenter + S.off)
                notify("Clone Tool", #S.bricks.." brick(s) remaining", 2)
            else
                notify("Clone Tool", "All bricks deselected.", 2)
                resetTool()
            end
        end
        return
    end

    if S.phase == "selected" and not S.selectMode then
        local key = getHoveredAxis()
        if key then
            local ray = Camera:ViewportPointToRay(mx, my)
            local pn  = bestPlaneNormal(AXIS_CFG[key].base)
            local hit = rayPlane(ray.Origin, ray.Direction*800, S.bCenter+S.off, pn)
            if hit then
                S.phase="dragging"; S.axis=key; S.dragOrig=hit; S.rawOff=S.off
            end
            return
        end
    end

    if S.phase == "idle" or S.phase == "selected" then
        resetTool()
        S.phase = "selecting"
        dragStart2D = Vector2.new(mx,my); dragEnd2D = dragStart2D
        showRect(true); setRect(dragStart2D, dragEnd2D)
    end
end)

UIS.InputChanged:Connect(function(inp, gp)
    if gp or not S.active then return end
    if inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end
    local mx, my = Mouse.X, Mouse.Y

    if S.phase == "selecting" then
        dragEnd2D = Vector2.new(mx,my); setRect(dragStart2D, dragEnd2D)

    elseif S.phase == "dragging" and S.axis and S.dragOrig and not S.selectMode then
        local ray = Camera:ViewportPointToRay(mx, my)
        local pn  = bestPlaneNormal(AXIS_CFG[S.axis].base)
        local hit = rayPlane(ray.Origin, ray.Direction*800, S.bCenter, pn)
        if hit then
            local delta = hit - S.dragOrig
            local dir   = AXIS_CFG[S.axis].dir
            S.rawOff   = S.rawOff + dir*delta:Dot(dir)
            S.off      = snapV3(S.rawOff)
            S.dragOrig = hit
            refreshPreview()
            placeHitParts(S.bCenter + S.off)
        end

    elseif S.selectMode and (S.phase == "selected" or S.phase == "dragging") then
        S.hovBrickIdx = findBrickIdxAtMouse(mx, my)
    end
end)

UIS.InputEnded:Connect(function(inp, gp)
    if gp or not S.active then return end
    if inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
    if S.phase == "selecting" then
        showRect(false)
        if (dragEnd2D-dragStart2D).Magnitude < MIN_DRAG then S.phase="idle"; return end
        local min2 = Vector2.new(math.min(dragStart2D.X,dragEnd2D.X), math.min(dragStart2D.Y,dragEnd2D.Y))
        local max2 = Vector2.new(math.max(dragStart2D.X,dragEnd2D.X), math.max(dragStart2D.Y,dragEnd2D.Y))
        for _, brick in ipairs(getAllBricks()) do
            if brickInScreenRect(brick, min2, max2) then table.insert(S.bricks, brick) end
        end
        if #S.bricks > 0 then
            S.phase = "selected"
            S.bCenter, S.bSize = calcBounds(S.bricks)
            spawnPreview(); placeHitParts(S.bCenter); setHitPartsActive(true)
            notify("Clone Tool", #S.bricks.." brick(s) selected  •  drag arrows  •  P select mode  •  Q to place", 3)
        else
            S.phase = "idle"
            notify("Clone Tool", "No bricks in that area.", 2)
        end
    elseif S.phase == "dragging" and not S.selectMode then
        S.phase = "selected"; S.axis = nil; S.dragOrig = nil
    end
end)

RS.RenderStepped:Connect(function()
    if not S.active then return end

    if SelModeGui.Enabled ~= (S.selectMode and S.active and (S.phase=="selected" or S.phase=="dragging")) then
        SelModeGui.Enabled = S.selectMode and S.active and (S.phase=="selected" or S.phase=="dragging")
    end

    S.hovAxis = (S.phase=="selected" and not S.selectMode) and getHoveredAxis()
              or (S.phase=="dragging" and not S.selectMode) and S.axis
              or nil

    if S.phase~="selected" and S.phase~="dragging" then return end

    local center   = S.bCenter + S.off
    local isFlash  = tick() < overlapFlashUntil
    local boxColor = isFlash and Color3.fromRGB(255, 50, 50) or TOOL_COLOR

    gizmo.reset()
    gizmo.setColor3(boxColor)
    gizmo.setTransparency(0.1)
    gizmo.setScale(1)
    gizmo.drawWireBox(CFrame.new(center), S.bSize + Vector3.new(0.3,0.3,0.3))

    if S.selectMode then
        for i, brick in ipairs(S.bricks) do
            local isHov    = (i == S.hovBrickIdx)
            local outColor = isHov and SEL_COLOR_HOVER or SEL_COLOR_NORMAL
            gizmo.reset()
            gizmo.setColor3(outColor)
            gizmo.setTransparency(isHov and 0 or 0.25)
            gizmo.setScale(isHov and 1.8 or 1.2)
            local pCF = brick.CFrame + S.off
            gizmo.drawWireBox(pCF, brick.Size + Vector3.new(0.18, 0.18, 0.18))
        end
    else
        for _, key in ipairs(AXES_ORDER) do
            local cfg      = AXIS_CFG[key]
            local isActive = (key==S.hovAxis)
            gizmo.reset()
            gizmo.setColor3(cfg.color)
            gizmo.setTransparency(isActive and 0 or 0.3)
            gizmo.setScale(isActive and 2.2 or 1)
            gizmo.drawArrow(center, center + cfg.dir*GZ_LEN)
        end
    end
end)
