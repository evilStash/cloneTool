-- buildblock() sourced directly from TCO Extras by 2areyoumental

local gizmo = (function()
    local gizmo = {}
    local DEFAULT_THICKNESS = 0.1
    local DEFAULT_SCALE     = 2
    local DEFAULT_COLOR     = Color3.new(1, 1, 1)
    local POINT_SCALE       = 5
    local RunService        = game:GetService("RunService")
    local Event             = RunService.RenderStepped

    local Gizmos = Instance.new("Folder", workspace)
    Gizmos.Name = "Gizmos"; Gizmos.Archivable = false

    local GizmoAnchor = Instance.new("Part")
    GizmoAnchor.Name        = "GizmoAnchor"
    GizmoAnchor.Anchored    = true
    GizmoAnchor.CanCollide  = false
    GizmoAnchor.CanQuery    = false
    GizmoAnchor.CastShadow  = false
    GizmoAnchor.Transparency = 1
    GizmoAnchor.Size        = Vector3.new(0.1, 0.1, 0.1)
    GizmoAnchor.CFrame      = CFrame.new(0, 0, 0)
    GizmoAnchor.Parent      = Gizmos

    local thickness    = DEFAULT_THICKNESS
    local globalScale  = DEFAULT_SCALE
    local globalOrigin = CFrame.new(0,0,0)
    local onRender     = nil
    local cache, queue, textQueue = {}, {}, {}

    local properties = {
        Adornee = GizmoAnchor, AlwaysOnTop = true,
        AdornCullingMode = Enum.AdornCullingMode.Automatic,
        Color3 = DEFAULT_COLOR, Visible = false, ZIndex = 1,
    }

    local function style(a) for k,v in pairs(properties) do a[k]=v end end
    local function get(cls)
        local c = cache[cls]; if not c then c={}; cache[cls]=c end
        return table.remove(c) or Instance.new(cls, Gizmos)
    end
    local function release(i)
        local c = cache[i.ClassName]; if not c then c={}; cache[i.ClassName]=c end
        table.insert(c, i)
    end

    function gizmo.setColor(c)   properties.Color3 = BrickColor.new(c).Color end
    function gizmo.setColor3(c)  properties.Color3 = c end
    function gizmo.setOrigin(o)  globalOrigin = o end
    function gizmo.setTransparency(t) properties.Transparency = t end
    function gizmo.setLayer(z)   properties.ZIndex = z end
    function gizmo.setScale(s)   globalScale = s end
    function gizmo.reset()
        properties.Transparency = 0; properties.ZIndex = 1
        properties.Color3 = DEFAULT_COLOR
        thickness = DEFAULT_THICKNESS; globalScale = DEFAULT_SCALE
        globalOrigin = CFrame.new(0,0,0)
    end

    function gizmo.drawBox(cf, sz)
        local a = get("BoxHandleAdornment"); style(a)
        a.Size=sz; a.CFrame=globalOrigin*cf; table.insert(queue,a)
    end

    function gizmo.drawWireBox(cf, sz)
        local x,y,z = sz.X/2, sz.Y/2, sz.Z/2
        local lw  = thickness * globalScale
        local sX  = Vector3.new(sz.X+lw, lw, lw)
        local sY  = Vector3.new(lw, sz.Y+lw, lw)
        local sZ  = Vector3.new(lw, lw, sz.Z+lw)
        local rel = globalOrigin * cf
        local function box(c2, s2) local a=get("BoxHandleAdornment"); style(a); a.Size=s2; a.CFrame=c2; table.insert(queue,a) end
        box(rel*CFrame.new( 0, y, z),sX); box(rel*CFrame.new( 0,-y, z),sX)
        box(rel*CFrame.new( 0, y,-z),sX); box(rel*CFrame.new( 0,-y,-z),sX)
        box(rel*CFrame.new( x, 0, z),sY); box(rel*CFrame.new(-x, 0, z),sY)
        box(rel*CFrame.new( x, 0,-z),sY); box(rel*CFrame.new(-x, 0,-z),sY)
        box(rel*CFrame.new( x, y, 0),sZ); box(rel*CFrame.new(-x, y, 0),sZ)
        box(rel*CFrame.new( x,-y, 0),sZ); box(rel*CFrame.new(-x,-y, 0),sZ)
    end

    function gizmo.drawPoint(pos)
        local a=get("SphereHandleAdornment"); style(a)
        a.Radius=globalScale*thickness*POINT_SCALE*0.5
        a.CFrame=globalOrigin*CFrame.new(pos); table.insert(queue,a)
    end

    function gizmo.drawLine(from, to)
        local d=(to-from).Magnitude; local a=get("CylinderHandleAdornment"); style(a)
        a.Radius=globalScale*thickness*0.5; a.InnerRadius=0; a.Height=d
        a.CFrame=globalOrigin*CFrame.lookAt(from,to)*CFrame.new(0,0,-d*0.5)
        table.insert(queue,a)
    end

    function gizmo.drawArrow(from, to)
        local ch = thickness*POINT_SCALE*globalScale
        local d  = math.abs((to-from).Magnitude - ch)
        local ori = globalOrigin * CFrame.lookAt(from, to)
        local ln = get("CylinderHandleAdornment"); style(ln)
        ln.Radius=globalScale*thickness*0.5; ln.InnerRadius=0; ln.Height=d
        ln.CFrame=ori*CFrame.new(0,0,-d*0.5)
        local cn = get("ConeHandleAdornment"); style(cn)
        cn.Height=ch; cn.Radius=ch*0.5; cn.CFrame=ori*CFrame.new(0,0,-d)
        table.insert(queue,ln); table.insert(queue,cn)
    end

    function gizmo.drawRay(from, dir) gizmo.drawArrow(from, from+dir) end

    function gizmo.clear()
        for _,a in ipairs(queue) do a.Visible=false; release(a) end; queue={}
    end

    local function enable()
        onRender = Event:Connect(function()
            local fr,tf = queue, textQueue; queue,textQueue = {},{}
            for _,a in ipairs(fr)  do a.Visible=true  end
            for _,a in ipairs(tf)  do a.Enabled=true  end
            Event:Wait()
            for _,a in ipairs(fr)  do a.Visible=false; release(a) end
            for _,a in ipairs(tf)  do a.Enabled=false; release(a) end
        end)
    end
    local function disable() if onRender then onRender:Disconnect(); onRender=nil end end

    workspace:GetAttributeChangedSignal("GizmosEnabled"):Connect(function()
        if workspace:GetAttribute("GizmosEnabled") then enable() else disable() end
    end)
    if workspace:GetAttribute("GizmosEnabled") then enable() end
    return gizmo
end)()

workspace:SetAttribute("GizmosEnabled", true)

local Players    = game:GetService("Players")
local UIS        = game:GetService("UserInputService")
local RS         = game:GetService("RunService")
local StarterGui = game:GetService("StarterGui")
local TCS        = game:GetService("TextChatService")
local WS         = game:GetService("Workspace")

local localplr   = Players.LocalPlayer
local Mouse      = localplr:GetMouse()
local Camera     = WS.CurrentCamera

local mult         = 4
local built        = false
local stopped      = false
local skipblock    = false
local novel        = false
local tp           = true
local colorbool    = false
local resizewait   = 0.4
local defaultcolor = Color3.fromRGB(192, 192, 192)
local oldprt       = nil
local childcube    = nil
local cubehistory  = {}
local historynum   = 0
local historymax   = 400
local buildingtoxify = false
local toxifybrick    = nil

local normalids = {}
normalids[Enum.NormalId.Right]  = {Vector3.new( 1,0,0),"X"}
normalids[Enum.NormalId.Top]    = {Vector3.new( 0,1,0),"Y"}
normalids[Enum.NormalId.Back]   = {Vector3.new( 0,0,1),"Z"}
normalids[Enum.NormalId.Left]   = {Vector3.new(-1,0,0),"X"}
normalids[Enum.NormalId.Bottom] = {Vector3.new( 0,-1,0),"Y"}
normalids[Enum.NormalId.Front]  = {Vector3.new( 0,0,-1),"Z"}

local function connectBrickFolder()
    local folder = WS.Bricks:FindFirstChild(localplr.Name)
    if folder then
        for _, child in ipairs(folder:GetChildren()) do
            if child:IsA("BasePart") then
                historynum  = (historynum % historymax) + 1
                cubehistory[historynum] = child
            end
        end
        folder.ChildAdded:Connect(function(child)
            childcube   = child
            historynum  = (historynum % historymax) + 1
            if buildingtoxify then toxifybrick = child end
            cubehistory[historynum] = child
            built = true
        end)
    end
end

if WS:FindFirstChild("Bricks") then
    connectBrickFolder()
    WS.Bricks.ChildAdded:Connect(function(child)
        if child.Name == localplr.Name then connectBrickFolder() end
    end)
end

local function roundnum(num, m)
    return math.round((num - 2) / m) * m + 2
end
local function round(pos, m)
    m = m or mult
    return Vector3.new(roundnum(pos.X,m), roundnum(pos.Y,m), roundnum(pos.Z,m))
end
local function snap(pos)
    return pos
end

local function buildblock(pos, texture, color, bsize, bsizev3, premadebuild, origmaterial, sprays, anchored, collide)
    task.wait(0.001)
    if anchored == nil then anchored = true  end
    if collide  == nil then collide  = true  end
    local needsresize = false
    local s, e = pcall(function()
        local s, e = pcall(function()
            localplr.Backpack.Build.Parent = localplr.Character
        end)
        local oo = false
        local c  = 0
        childcube = nil
        if #cubehistory > 0 and oldprt then
            local allooslol = {}
            for i, childcube2 in pairs(cubehistory) do
                if childcube2 == nil or childcube2.Parent == nil then
                    cubehistory[i] = nil
                    continue
                elseif oldprt.Size == childcube2.Size then
                    for ni, nv in pairs(normalids) do
                        local npos = childcube2.Position + (nv[1] * childcube2.Size[nv[2]])
                        if npos == oldprt.Position then
                            oo = {ni, childcube2, childcube2.Position + (nv[1] * childcube2.Size[nv[2]] / 2)}
                            table.insert(allooslol, {ni, childcube2, childcube2.Position + (nv[1] * childcube2.Size[nv[2]] / 2)})
                        end
                    end
                end
            end
            if #allooslol > 1 and color and oo[2].Color ~= color then
                for _, v in pairs(allooslol) do
                    if v[2].Color == color then oo = v end
                end
            end
            local origposs = pos
            if oo and oo[2] ~= nil and oo[2].Parent ~= nil then
                local args = { [1]=oo[2], [2]=oo[1], [3]=oo[3] or oldprt.Position, [4]="normal" }
                built = false; childcube = nil; c = 0
                repeat
                    c = c + 1
                    if localplr.Character:FindFirstChild("Build") then
                        local ev = localplr.Character.Build
                        local _ = (ev:FindFirstChild("origevent") and ev.origevent:Invoke(table.unpack(args)))
                            or ev.Script.Event:FireServer(table.unpack(args))
                    else
                        pcall(function() localplr.Backpack.Build.Parent = localplr.Character end)
                    end
                    pcall(function()
                        novel = true
                        pos = oo[3] or pos
                        if tp then localplr.Character.HumanoidRootPart.CFrame = CFrame.new(pos) end
                    end)
                    task.wait(0.05)
                until (built == true and childcube) or oo[2]==nil or oo[2].Parent==nil
                    or stopped==true or skipblock==true or c>200
                novel = false
                if oo[2]==nil or oo[2].Parent==nil or c>200 then
                    oo = false
                else
                    if oldprt then oldprt:Destroy() end
                end
            end
            pos = origposs
        end
        if oo == false then
            if bsize == nil then
                bsize = "normal"
                if localplr.PlayerGui:FindFirstChild("Build") and localplr.PlayerGui.Build:FindFirstChild("Button") then
                    bsize = localplr.PlayerGui.Build.Button.Text
                end
                if bsizev3 ~= nil and (bsizev3.X ~= mult or bsizev3.Y ~= mult or bsizev3.Z ~= mult) then
                    bsize = "detailed"
                elseif bsizev3 ~= nil and (bsizev3.X == mult and bsizev3.Y == mult and bsizev3.Z == mult) then
                    bsize = "normal"
                end
                if bsizev3==nil and bsize~="detailed" and oldprt and oldprt.Position ~= round(pos) then
                    bsize = "detailed"
                    needsresize = true
                    bsizev3 = Vector3.new(4,4,4)
                    pos = Vector3.new((pos.X-(bsizev3.X/2))+.5, (pos.Y-(bsizev3.Y/2))+.5, (pos.Z-(bsizev3.Z/2))+.5)
                end
            end
            local oldpos = pos
            pos = snap(pos)
            local args = { [1]=workspace.Terrain, [2]=Enum.NormalId.Top, [3]=pos, [4]=bsize or "normal" }
            built = false
            pcall(function()
                local ev = localplr.Character.Build
                local _ = (ev:FindFirstChild("origevent") and ev.origevent:Invoke(table.unpack(args)))
                    or ev.Script.Event:FireServer(table.unpack(args))
            end)
            c = 0
            repeat
                c = c + 1
                if localplr.Character and not localplr.Character:FindFirstChild("Build") and localplr.Backpack:FindFirstChild("Build") then
                    localplr.Backpack.Build.Parent = localplr.Character
                end
                if localplr.Character:FindFirstChild("Build") then
                    local ev = localplr.Character.Build
                    local _ = (ev:FindFirstChild("origevent") and ev.origevent:Invoke(table.unpack(args)))
                        or ev.Script.Event:FireServer(table.unpack(args))
                end
                pcall(function()
                    novel = true
                    if tp then
                        localplr.Character.HumanoidRootPart.CFrame = CFrame.new(pos + Vector3.new(0,6,0))
                    end
                end)
                task.wait(0.1)
            until (built==true and childcube) or stopped==true or skipblock==true or c>200
            novel = false; built = false; c = 0
        end
        if childcube and typeof(color)=="Color3"
            and (color~=defaultcolor or (childcube.Color~=color or childcube.Material~=texture))
            and (localplr.Backpack:FindFirstChild("Paint") or localplr.Character:FindFirstChild("Paint"))
            and ((colorbool and premadebuild~=nil) or not colorbool) or texture then
            local ppos = (childcube and childcube.Position + childcube.Size/2) or pos
            local args = {
                [1]=childcube, [2]=Enum.NormalId.Top, [3]=ppos,
                [4]="color", [5]=color or nil, [6]="tiles", [7]=""
            }
            task.wait()
            pcall(function() localplr.Backpack.Paint.Parent = localplr.Character end)
            if texture ~= nil then
                args[4] = color==nil and "material" or "both \u{1F91D}"
                args[6] = texture
            end
            if not childcube then if oldprt then oldprt:Destroy() end; return end
            c = 0
            pcall(function()
                repeat
                    c = c + 1
                    if localplr.Character and not localplr.Character:FindFirstChild("Paint") and localplr.Backpack:FindFirstChild("Paint") then
                        localplr.Backpack.Paint.Parent = localplr.Character
                    end
                    if localplr.Character and localplr.Character:FindFirstChild("Paint") then
                        local ev = localplr.Character.Paint
                        local _ = (ev:FindFirstChild("origevent") and ev.origevent:Invoke(table.unpack(args)))
                            or ev.Script.Event:FireServer(table.unpack(args))
                    end
                    pcall(function()
                        novel = true
                        if tp then localplr.Character.HumanoidRootPart.CFrame = CFrame.new(ppos+Vector3.new(0,6,0)) end
                    end)
                    task.wait(0.2)
                until not childcube or not childcube.Parent
                    or childcube.Color==color
                    or (texture and childcube.Material==Enum.Material[origmaterial])
                    or stopped==true or skipblock==true or c>2000
                novel = false
            end)
        end
        if childcube and localplr.Character and localplr.Character:FindFirstChild("Paint") and childcube.Anchored~=anchored then
            local ppos = (childcube and childcube.Position+childcube.Size/2) or pos
            local args = { [1]=childcube, [2]=Enum.NormalId.Top, [3]=ppos, [4]="material", [5]=nil, [6]="anchor", [7]="" }
            c = 0
            repeat
                c = c + 1
                if localplr.Character and not localplr.Character:FindFirstChild("Paint") and localplr.Backpack:FindFirstChild("Paint") then
                    localplr.Backpack.Paint.Parent = localplr.Character
                end
                if localplr.Character and localplr.Character:FindFirstChild("Paint") and childcube and childcube.Anchored~=anchored then
                    local ev = localplr.Character.Paint
                    local _ = (ev:FindFirstChild("origevent") and ev.origevent:Invoke(table.unpack(args)))
                        or ev.Script.Event:FireServer(table.unpack(args))
                end
                pcall(function()
                    novel = true
                    if tp then localplr.Character.HumanoidRootPart.CFrame = CFrame.new(ppos+Vector3.new(0,8,0)) end
                end)
                task.wait(1)
            until not childcube or not childcube.Parent or childcube.Anchored==anchored
                or stopped==true or skipblock==true or c>20
            novel = false
        end
        if childcube and localplr.Character and localplr.Character:FindFirstChild("Paint") and childcube.CanCollide~=collide then
            local ppos = (childcube and childcube.Position+childcube.Size/2) or pos
            local args = { [1]=childcube, [2]=Enum.NormalId.Top, [3]=ppos, [4]="material", [5]=nil, [6]="collide", [7]="" }
            c = 0
            repeat
                c = c + 1
                if localplr.Character and not localplr.Character:FindFirstChild("Paint") and localplr.Backpack:FindFirstChild("Paint") then
                    localplr.Backpack.Paint.Parent = localplr.Character
                end
                if localplr.Character and localplr.Character:FindFirstChild("Paint") and childcube and childcube.CanCollide~=collide then
                    local ev = localplr.Character.Paint
                    local _ = (ev:FindFirstChild("origevent") and ev.origevent:Invoke(table.unpack(args)))
                        or ev.Script.Event:FireServer(table.unpack(args))
                end
                pcall(function()
                    novel = true
                    if tp then localplr.Character.HumanoidRootPart.CFrame = CFrame.new(ppos+Vector3.new(0,8,0)) end
                end)
                task.wait(1)
            until not childcube or not childcube.Parent or childcube.CanCollide==collide
                or stopped==true or skipblock==true or c>20
            novel = false
        end
        if childcube and ((bsizev3~=nil and (bsizev3.X~=mult or bsizev3.Y~=mult or bsizev3.Z~=mult)) or needsresize==true)
            and (localplr.Character:FindFirstChild("Shape") or localplr.Backpack:FindFirstChild("Shape")) then
            if not localplr.Character:FindFirstChild("Shape") and localplr.Backpack:FindFirstChild("Shape") then
                localplr.Backpack.Shape.Parent = localplr.Character
            end
            local args = { [1]=childcube, [2]=Enum.NormalId.Right, [3]="", [4]="" }
            local function resize(normalId, axis)
                args[2] = normalId; c = 0
                if childcube and childcube.Size[axis] ~= bsizev3[axis] then
                    repeat
                        c = c + 1
                        local ppos = (childcube and childcube.Position+childcube.Size/2) or pos
                        args[4] = nil
                        if childcube then
                            args[3] = ppos
                            if     childcube.Size[axis] > bsizev3[axis] then args[4]="decrease"
                            elseif childcube.Size[axis] < bsizev3[axis] then args[4]="increase" end
                        end
                        if not localplr.Character:FindFirstChild("Shape") and localplr.Backpack:FindFirstChild("Shape") then
                            localplr.Backpack.Shape.Parent = localplr.Character
                        end
                        if localplr.Character:FindFirstChild("Shape") then
                            local ev = localplr.Character.Shape
                            local _ = (ev:FindFirstChild("origevent") and ev.origevent:Invoke(table.unpack(args)))
                                or ev.Script.Event:FireServer(table.unpack(args))
                        end
                        pcall(function()
                            novel = true
                            if tp then localplr.Character.HumanoidRootPart.CFrame = CFrame.new(args[3]+Vector3.new(0,6,0)) end
                        end)
                        task.wait(resizewait)
                    until args[4]==nil
                        or (args[4]=="decrease" and childcube and childcube.Size[axis]<=1)
                        or (childcube and childcube.Size[axis]==bsizev3[axis])
                        or stopped==true or skipblock==true
                        or not childcube or not childcube.Parent
                        or c > (bsizev3[axis]*3)/resizewait
                    novel = false
                end
            end
            resize(Enum.NormalId.Right, "X")
            resize(Enum.NormalId.Top,   "Y")
            resize(Enum.NormalId.Back,  "Z")
        end
        skipblock = false
    end)
    if oldprt then oldprt:Destroy() end
    novel = false; childcube = nil
    if not s then print(e) end
end

