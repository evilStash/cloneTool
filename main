local MAX_QUICK_SAVES = 5
local quickSaves = {}

local function snapshotFingerprint(brickData)
    if #brickData == 0 then return "" end
    local cx, cy, cz = 0, 0, 0
    for _, bd in ipairs(brickData) do
        local p = bd.CFrame.Position
        cx = cx + math.round(p.X)
        cy = cy + math.round(p.Y)
        cz = cz + math.round(p.Z)
    end
    local n = #brickData
    cx = math.round(cx / n)
    cy = math.round(cy / n)
    cz = math.round(cz / n)
    local parts = {}
    for _, bd in ipairs(brickData) do
        local p = bd.CFrame.Position
        table.insert(parts, string.format("%d,%d,%d|%d,%d,%d|%d,%d,%d|%s|%s|%s",
            math.round(p.X) - cx, math.round(p.Y) - cy, math.round(p.Z) - cz,
            math.round(bd.Size.X), math.round(bd.Size.Y), math.round(bd.Size.Z),
            math.round(bd.Color.R * 255), math.round(bd.Color.G * 255), math.round(bd.Color.B * 255),
            bd.Material.Name,
            tostring(bd.Anchored),
            tostring(bd.CanCollide)
        ))
    end
    table.sort(parts)
    return table.concat(parts, ";")
end

local function saveSnapshot()
    if #(S and S.bricks or {}) == 0 then return end
    local snap = {
        brickData = {},
        off       = S.off,
        center    = S.bCenter,
        bSize     = S.bSize,
        label     = #S.bricks .. " brick" .. (#S.bricks == 1 and "" or "s"),
    }
    for _, b in ipairs(S.bricks) do
        table.insert(snap.brickData, {
            CFrame     = b.CFrame,
            Size       = b.Size,
            Color      = b.Color,
            Material   = b.Material,
            Anchored   = b:GetAttribute("OrigAnchored")   ~= nil and b:GetAttribute("OrigAnchored")   or b.Anchored,
            CanCollide = b:GetAttribute("OrigCanCollide") ~= nil and b:GetAttribute("OrigCanCollide") or b.CanCollide,
        })
    end
    snap.fingerprint = snapshotFingerprint(snap.brickData)
    for _, existing in ipairs(quickSaves) do
        if existing.fingerprint == snap.fingerprint then return end
    end
    table.insert(quickSaves, 1, snap)
    if #quickSaves > MAX_QUICK_SAVES then
        table.remove(quickSaves)
    end
end

local function makeLabel(parent, text, anchorX, posX, posY, sizeX, sizeY, textColor, strokeColor)
    local l = Instance.new("TextLabel")
    l.AnchorPoint            = Vector2.new(anchorX, 0.5)
    l.Position               = UDim2.new(posX, 0, posY, 0)
    l.Size                   = UDim2.new(sizeX, 0, sizeY, 0)
    l.BackgroundTransparency = 1
    l.BorderSizePixel        = 0
    l.Font                   = Enum.Font.FredokaOne
    l.Text                   = text
    l.TextColor3             = textColor or Color3.fromRGB(255,255,255)
    l.TextScaled             = true
    l.TextStrokeColor3       = strokeColor or Color3.fromRGB(128,128,128)
    l.TextStrokeTransparency = 0
    l.TextWrapped            = true
    l.Parent                 = parent
    return l
end

local function makeTextBox(parent, placeholderText, anchorX, posX, posY, sizeX, sizeY)
    local tb = Instance.new("TextBox")
    tb.AnchorPoint            = Vector2.new(anchorX, 0.5)
    tb.Position               = UDim2.new(posX, 0, posY, 0)
    tb.Size                   = UDim2.new(sizeX, 0, sizeY, 0)
    tb.BackgroundColor3       = Color3.fromRGB(20, 20, 20)
    tb.BackgroundTransparency = 0.4
    tb.BorderSizePixel        = 0
    tb.Font                   = Enum.Font.FredokaOne
    tb.PlaceholderText        = placeholderText
    tb.PlaceholderColor3      = Color3.fromRGB(180,180,180)
    tb.Text                   = ""
    tb.TextColor3             = Color3.fromRGB(255,255,255)
    tb.TextScaled             = true
    tb.TextStrokeColor3       = Color3.fromRGB(0,0,0)
    tb.TextStrokeTransparency = 0.5
    tb.ClearTextOnFocus       = true
    tb.Parent                 = parent
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0.2, 0)
    corner.Parent = tb
    local stroke = Instance.new("UIStroke")
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Color           = TOOL_COLOR
    stroke.Thickness       = 1.5
    stroke.Parent          = tb
    return tb
end

